---
interface Props {
  date: string;
  company: string;
  companyUrl?: string;
  location: string;
  role: string;
  bullets: string[];
}
const { date, company, companyUrl, location, role, bullets } = Astro.props;
---
<div class="fade-in grid grid-cols-[200px_1fr] gap-12 py-10
            border-b border-site-border first:border-t first:border-site-border">

  <!-- Meta -->
  <div class="pt-1">
    <p class="font-mono text-2xs text-site-muted tracking-wider mb-2">{date}</p>
    <p class="text-sm font-medium text-site-accent mb-1">
      {companyUrl
        ? <a href={companyUrl} target="_blank" class="text-site-accent no-underline hover:underline">{company}</a>
        : company}
    </p>
    <p class="font-mono text-2xs text-site-muted tracking-wide">{location}</p>
  </div>

  <!-- Body -->
  <div>
    <p class="font-playfair text-lg font-normal text-site-text mb-4">{role}</p>
    <ul class="flex flex-col gap-2 list-none">
      {bullets.map(bullet => (
        <li class="text-sm text-site-muted leading-7 pl-5 relative
                   before:content-['—'] before:absolute before:left-0
                   before:text-site-accent before:text-xs before:top-0.5"
            set:html={bullet} />
      ))}
    </ul>
  </div>
</div>
