---
/**
 * Renders a phone number that is invisible to scrapers.
 * Parts are base64-encoded in data attributes and assembled client-side.
 *
 * Props:
 *   parts — array of phone segments e.g. ["650","285","7980"]
 *   sep   — separator between parts, default "."
 *   class — optional Tailwind classes
 */
interface Props {
  parts: string[];
  sep?: string;
  class?: string;
}
const { parts, sep = '.', class: cls = '' } = Astro.props;
---
<span
  class={`obf-phone ${cls}`}
  data-parts={btoa(JSON.stringify(parts))}
  data-sep={btoa(sep)}
  aria-label="Phone number"
>
  <!--phone protected-->
</span>
