---
interface Props {
  tag: string;
  title: string;
  description: string;
  reportUrl?: string;
  videoUrl?: string;
}
const { tag, title, description, reportUrl, videoUrl } = Astro.props;
---
<div class="bg-site-bg2 border border-site-border p-8
            transition-colors hover:border-site-accent">
  <p class="font-mono text-2xs text-site-accent2 tracking-widest uppercase mb-3">
    {tag}
  </p>
  <h3 class="font-playfair text-xl font-normal mb-3">{title}</h3>
  <p class="text-sm text-site-muted leading-7">{description}</p>

  {reportUrl && (
    <a href={reportUrl}
       class="block mt-4 font-mono text-xs text-site-accent tracking-wider no-underline hover:underline">
      Read Report →
    </a>
  )}
  {videoUrl && (
    <div class="mt-4 relative pt-[56.25%]">
      <iframe
        src={videoUrl}
        frameborder="0"
        allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        class="absolute top-0 left-0 w-full h-full"
      />
    </div>
  )}
</div>
