---
/**
 * Renders an email link that is invisible to scrapers.
 * The email address never appears in HTML source — it is assembled
 * client-side from data attributes by obfuscate.js.
 *
 * Props:
 *   user   — the part before @
 *   domain — the part after @
 *   class  — optional extra Tailwind classes for the <a> tag
 *   label  — optional display text (defaults to assembled address)
 */
interface Props {
  user: string;
  domain: string;
  class?: string;
  label?: string;
}
const { user, domain, class: cls = '', label } = Astro.props;
---
<a
  href="#"
  class={`obf-email ${cls}`}
  data-u={btoa(user)}
  data-d={btoa(domain)}
  data-label={label ? btoa(label) : ''}
  aria-label="Send email"
>
  <!--email protected-->
</a>
