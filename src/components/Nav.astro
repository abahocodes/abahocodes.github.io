---
import { Icon } from 'astro-icon/components';

interface Social {
  label: string; href: string; display: string;
  icon: string; obfuscated?: boolean;
}
interface Props { socials: Social[]; emailUser: string; emailDomain: string; }

const { socials, emailUser, emailDomain } = Astro.props;
const navLinks = ['about', 'experience', 'education', 'projects', 'skills', 'resume', 'contact'];
const emailSocial = socials.find(s => s.obfuscated);
---

<nav class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center
            px-6 md:px-12 py-5 border-b border-site-border"
     style="background: color-mix(in srgb, var(--color-bg) 92%, transparent); backdrop-filter: blur(12px);">

  <a href="#hero" class="font-playfair font-bold text-lg text-site-accent no-underline">
    AK
  </a>

  <!-- Desktop nav links -->
  <ul class="hidden md:flex gap-10 list-none">
    {navLinks.map(link => (
      <li>
        <a href={`#${link}`}
           class="text-site-muted no-underline text-2xs font-mono tracking-widest
                  uppercase transition-colors hover:text-site-text">
          {link}
        </a>
      </li>
    ))}
  </ul>

  <!-- Right: social icons + theme toggle (always visible) -->
  <div class="flex items-center gap-3">

    <!-- Social icons: hidden on mobile -->
    <div class="hidden md:flex items-center gap-3">
      {socials.filter(s => !s.obfuscated).map(s => (
        <a href={s.href} target="_blank" rel="noopener noreferrer"
           aria-label={s.label}
           class="text-site-muted hover:text-site-accent transition-colors p-1">
          <Icon name={s.icon} class="w-[18px] h-[18px]" aria-hidden="true" />
        </a>
      ))}
      {emailSocial && (
        <a href="#"
           class="obf-email text-site-muted hover:text-site-accent transition-colors p-1"
           data-u={btoa(emailUser)}
           data-d={btoa(emailDomain)}
           data-icon-only="true"
           aria-label="Email">
          <Icon name={emailSocial.icon} class="w-[18px] h-[18px]" aria-hidden="true" />
        </a>
      )}
      <div class="w-px h-4 bg-site-border mx-1"></div>
    </div>

    <!-- Theme toggle: always visible -->
    <button
      id="theme-toggle"
      aria-label="Toggle light/dark theme"
      title="Toggle theme"
      class="text-site-muted hover:text-site-accent transition-colors
             flex items-center justify-center w-7 h-7
             border border-transparent hover:border-site-border rounded-none"
    >
      <Icon name="lucide:sun"  class="w-[18px] h-[18px]" id="icon-sun"  aria-hidden="true" />
      <Icon name="lucide:moon" class="w-[18px] h-[18px]" id="icon-moon" aria-hidden="true" style="display:none" />
    </button>

    <!-- Hamburger: mobile only -->
    <button
      id="menu-toggle"
      aria-label="Open menu"
      class="md:hidden text-site-muted hover:text-site-accent transition-colors
             flex items-center justify-center w-7 h-7 ml-1"
    >
      <Icon name="lucide:menu" class="w-[20px] h-[20px]" id="icon-menu" aria-hidden="true" />
      <Icon name="lucide:x"    class="w-[20px] h-[20px]" id="icon-close" aria-hidden="true" style="display:none" />
    </button>
  </div>
</nav>

<!-- Mobile menu drawer -->
<div id="mobile-menu"
     class="fixed top-[65px] left-0 right-0 z-40 border-b border-site-border
            md:hidden hidden flex-col"
     style="background: var(--color-bg);">
  {navLinks.map(link => (
    <a href={`#${link}`}
       class="mobile-nav-link px-6 py-4 border-b border-site-border
              font-mono text-xs tracking-widest uppercase text-site-muted
              hover:text-site-text hover:bg-site-bg2 transition-colors no-underline">
      {link}
    </a>
  ))}
  <!-- Social links in mobile menu -->
  <div class="flex gap-5 px-6 py-5">
    {socials.filter(s => !s.obfuscated).map(s => (
      <a href={s.href} target="_blank" rel="noopener noreferrer"
         aria-label={s.label}
         class="text-site-muted hover:text-site-accent transition-colors">
        <Icon name={s.icon} class="w-5 h-5" aria-hidden="true" />
      </a>
    ))}
    {emailSocial && (
      <a href="#"
         class="obf-email text-site-muted hover:text-site-accent transition-colors"
         data-u={btoa(emailUser)}
         data-d={btoa(emailDomain)}
         data-icon-only="true"
         aria-label="Email">
        <Icon name={emailSocial.icon} class="w-5 h-5" aria-hidden="true" />
      </a>
    )}
  </div>
</div>

<script>
  // ── Theme toggle ──────────────────────────────────────────────────────────
  const html     = document.documentElement;
  const btn      = document.getElementById('theme-toggle')!;
  const iconSun  = document.getElementById('icon-sun')!;
  const iconMoon = document.getElementById('icon-moon')!;

  function applyTheme(theme: string) {
    if (theme === 'light') {
      html.classList.add('light');
      iconSun.style.display  = 'none';
      iconMoon.style.display = 'block';
    } else {
      html.classList.remove('light');
      iconSun.style.display  = 'block';
      iconMoon.style.display = 'none';
    }
  }

  btn.addEventListener('click', () => {
    const next = html.classList.contains('light') ? 'dark' : 'light';
    localStorage.setItem('theme', next);
    applyTheme(next);
  });

  // ── Mobile menu toggle ────────────────────────────────────────────────────
  const menuBtn    = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconMenu   = document.getElementById('icon-menu')!;
  const iconClose  = document.getElementById('icon-close')!;

  menuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    if (isOpen) {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      iconMenu.style.display  = 'block';
      iconClose.style.display = 'none';
    } else {
      mobileMenu.classList.remove('hidden');
      mobileMenu.classList.add('flex');
      iconMenu.style.display  = 'none';
      iconClose.style.display = 'block';
    }
  });

  // Close menu when a link is tapped
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      iconMenu.style.display  = 'block';
      iconClose.style.display = 'none';
    });
  });
</script>
