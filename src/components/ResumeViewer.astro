---
/**
 * Scrollable inline PDF viewer for the resume.
 * Falls back to a download link if the browser can't embed PDFs (mobile).
 */
interface Props {
  src?: string;
}
const { src = '/resume.pdf' } = Astro.props;
---

<div class="fade-in relative w-full rounded-none border border-site-border overflow-hidden"
     style="height: 680px;">

  <!-- Desktop: embedded PDF viewer -->
  <object
    data={src}
    type="application/pdf"
    class="pdf-embed w-full h-full block"
    aria-label="Resume PDF viewer"
  >
    <!-- Fallback for mobile / browsers without PDF support -->
    <div class="flex flex-col items-center justify-center h-full gap-5
                bg-site-bg2 text-site-muted text-sm font-mono">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="1.5" class="text-site-accent opacity-60">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10 9 9 9 8 9"/>
      </svg>
      <p class="text-site-muted text-xs tracking-wider">PDF preview not available in this browser</p>
      <a href={src} download
         class="font-mono text-xs tracking-widest uppercase px-5 py-2.5 border
                bg-site-accent border-site-accent text-site-bg
                transition-all hover:bg-transparent hover:text-site-accent no-underline">
        Download Resume
      </a>
    </div>
  </object>
</div>

<!-- Toolbar below viewer -->
<div class="flex items-center justify-between mt-3 px-1">
  <p class="font-mono text-2xs text-site-muted tracking-wider">
    resume.pdf · scroll to read
  </p>
  <a href={src} download
     class="font-mono text-2xs text-site-accent tracking-widest uppercase
            no-underline hover:underline">
    Download ↓
  </a>
</div>
