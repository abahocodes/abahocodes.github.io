---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SocialLink from '../components/SocialLink.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ResumeViewer from '../components/ResumeViewer.astro';
import ObfuscatedEmail from '../components/ObfuscatedEmail.astro';
import ObfuscatedPhone from '../components/ObfuscatedPhone.astro';

import person      from '../data/person.json';
import socials     from '../data/socials.json';
import heroStats   from '../data/hero-stats.json';
import aboutFacts  from '../data/about-facts.json';
import education   from '../data/education.json';
import experience  from '../data/experience.json';
import projects    from '../data/projects.json';
import skills      from '../data/skills.json';
---

<Layout title={`${person.name} — ${person.tagline}`}>
  <Nav
    socials={socials}
    emailUser={person.emailUser}
    emailDomain={person.emailDomain}
  />

  <!-- ── HERO ── -->
  <div id="hero" class="min-h-screen flex items-center px-6 md:px-12 pt-28 md:pt-32 pb-12 md:pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 max-w-5xl mx-auto w-full">

      <div class="flex flex-col justify-center">
        <p class="font-mono text-2xs text-site-accent tracking-widest uppercase mb-6">
          {person.tagline} — {person.location}
        </p>
        <h1 class="font-playfair font-bold leading-none tracking-tight mb-6"
            style="font-size: clamp(3rem, 6vw, 5.5rem)">
          {person.name.split(' ')[0]}<br />
          <span class="text-site-accent">{person.name.split(' ')[1]}</span>
        </h1>
        <p class="text-base text-site-muted max-w-md mb-10 leading-loose">
          {person.heroSubtitle}
        </p>
        <div class="flex gap-4 flex-wrap">
          <a href="/resume.pdf"
             class="font-mono text-xs tracking-widest uppercase px-6 py-3 border
                    bg-site-accent border-site-accent text-site-bg
                    transition-all hover:bg-transparent hover:text-site-accent no-underline">
            Download Resume
          </a>
          <a href="#contact"
             class="font-mono text-xs tracking-widest uppercase px-6 py-3 border
                    border-site-border text-site-muted
                    transition-all hover:border-site-muted hover:text-site-text no-underline">
            Get in Touch
          </a>
        </div>
      </div>

      <div class="flex flex-col justify-center border-t md:border-t-0 md:border-l border-site-border pt-8 md:pt-0 md:pl-16">
        {heroStats.map(stat => (
          <div class="py-6 border-b border-site-border first:border-t first:border-site-border">
            <p class="font-mono text-2xs text-site-muted tracking-widest uppercase mb-1">{stat.label}</p>
            <p class="text-[0.95rem] text-site-text" set:html={stat.value} />
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── ABOUT ── -->
  <section id="about" class="border-t border-site-border max-w-5xl mx-auto px-6 md:px-12 py-16 md:py-24">
    <SectionHeader number="01" title="About" />
    <div class="fade-in grid grid-cols-1 md:grid-cols-[260px_1fr_1fr] gap-10 md:gap-16 items-start">

      <div>
        <img
          src="/photo.jpg"
          alt={person.name}
          class="w-full max-w-[260px] md:max-w-none h-auto block"
          style="filter: grayscale(20%)"
        />
      </div>

      <div class="space-y-5 text-[0.95rem] text-site-muted leading-loose">
        {person.bio.map(para => <p set:html={para} />)}
      </div>

      <!-- Facts + social rows -->
      <div>
        {aboutFacts.map(f => (
          <div class="flex justify-between items-center py-4
                      border-b border-site-border first:border-t first:border-site-border text-sm">
            <span class="font-mono text-2xs text-site-muted tracking-wider uppercase">{f.key}</span>
            <span class="text-site-text text-right" set:html={f.val} />
          </div>
        ))}

        <!-- Non-email socials with icons -->
        {socials.filter(s => !s.obfuscated).map(s => (
          <div class="flex justify-between items-center py-4 border-b border-site-border text-sm">
            <span class="font-mono text-2xs text-site-muted tracking-wider uppercase">{s.label}</span>
            <SocialLink
              href={s.href}
              label={s.display}
              icon={s.icon}
              class="text-site-accent text-sm gap-1.5"
            />
          </div>
        ))}

        <!-- Obfuscated email row with icon -->
        <div class="flex justify-between items-center py-4 border-b border-site-border text-sm">
          <span class="font-mono text-2xs text-site-muted tracking-wider uppercase">Email</span>
          <ObfuscatedEmail
            user={person.emailUser}
            domain={person.emailDomain}
            class="text-site-accent no-underline text-sm"
          />
        </div>

        <!-- Obfuscated phone row -->
        <div class="flex justify-between items-center py-4 border-b border-site-border text-sm">
          <span class="font-mono text-2xs text-site-muted tracking-wider uppercase">Phone</span>
          <ObfuscatedPhone parts={person.phoneParts} class="text-site-text" />
        </div>
      </div>
    </div>
  </section>

  <!-- ── EXPERIENCE ── -->
  <section id="experience" class="border-t border-site-border max-w-5xl mx-auto px-6 md:px-12 py-16 md:py-24">
    <SectionHeader number="02" title="Experience" />
    <div>
      {experience.map(job => <ExperienceItem {...job} />)}
    </div>
  </section>

  <!-- ── EDUCATION ── -->
  <section id="education" class="border-t border-site-border max-w-5xl mx-auto px-6 md:px-12 py-16 md:py-24">
    <SectionHeader number="03" title="Education" />
    <div class="fade-in grid grid-cols-1 sm:grid-cols-2 gap-6">
      {education.map(e => (
        <div class="bg-site-bg2 border border-site-border p-8">
          <p class="font-mono text-2xs text-site-accent tracking-widest mb-4">{e.years}</p>
          <h3 class="font-playfair text-2xl font-normal mb-2">{e.school}</h3>
          <p class="text-sm text-site-muted">{e.degree}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── PROJECTS ── -->
  <section id="projects" class="border-t border-site-border max-w-5xl mx-auto px-6 md:px-12 py-16 md:py-24">
    <SectionHeader number="04" title="Projects" />
    <div class="fade-in grid grid-cols-1 sm:grid-cols-2 gap-6">
      {projects.map(p => <ProjectCard {...p} />)}
    </div>
  </section>

  <!-- ── SKILLS ── -->
  <section id="skills" class="border-t border-site-border max-w-5xl mx-auto px-6 md:px-12 py-16 md:py-24">
    <SectionHeader number="05" title="Skills" />
    <div class="fade-in grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {skills.map(group => (
        <div class="bg-site-bg2 border border-site-border p-7">
          <p class="font-mono text-2xs text-site-accent tracking-widest uppercase mb-5">{group.group}</p>
          <div class="flex flex-wrap gap-2">
            {group.tags.map(tag => (
              <span class="font-mono text-xs text-site-muted bg-site-bg3
                           border border-site-border px-3 py-1 tracking-wide">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── RESUME VIEWER ── -->
  <section id="resume" class="border-t border-site-border max-w-5xl mx-auto px-6 md:px-12 py-16 md:py-24">
    <SectionHeader number="06" title="Resume" />
    <ResumeViewer />
  </section>

  <!-- ── CONTACT ── -->
  <section id="contact"
           class="border-t border-site-border max-w-5xl mx-auto px-6 md:px-12 py-16 md:py-24 text-center">
    <div class="max-w-lg mx-auto fade-in">
      <p class="font-mono text-2xs text-site-accent tracking-widest uppercase mb-4">07 — Contact</p>
      <h2 class="font-playfair text-5xl font-normal mb-4">Let's Talk</h2>
      <p class="text-sm text-site-muted mb-10 leading-loose">
        Whether you're interested in App Maker, have a technical problem worth solving,
        or just want to connect — my inbox is open.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <ObfuscatedEmail
          user={person.emailUser}
          domain={person.emailDomain}
          label="Send an Email"
          class="font-mono text-xs tracking-widest uppercase px-6 py-3 border
                 bg-site-accent border-site-accent text-site-bg
                 transition-all hover:bg-transparent hover:text-site-accent no-underline"
        />
        {socials.filter(s => !s.obfuscated).map(s => (
          <SocialLink
            href={s.href}
            label={s.label}
            icon={s.icon}
            class="font-mono text-xs tracking-widest uppercase px-6 py-3 border
                   border-site-border text-site-muted gap-2
                   transition-all hover:border-site-muted hover:text-site-text"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="border-t border-site-border px-6 md:px-12 py-8 flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="font-mono text-2xs text-site-muted tracking-wider">
      © {new Date().getFullYear()} {person.name}
    </p>
    <div class="flex items-center gap-5">
      {socials.filter(s => !s.obfuscated).map(s => (
        <SocialLink
          href={s.href}
          label={s.label}
          icon={s.icon}
          iconOnly={true}
          class="text-site-muted hover:text-site-accent"
        />
      ))}
      <!-- Obfuscated email icon in footer -->
      <a href="#"
         class="obf-email text-site-muted hover:text-site-accent transition-colors
                inline-flex items-center"
         data-u={btoa(person.emailUser)}
         data-d={btoa(person.emailDomain)}
         data-icon-only="true"
         aria-label="Email">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
             stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        <span class="sr-only">Email</span>
      </a>
    </div>
  </footer>

</Layout>
